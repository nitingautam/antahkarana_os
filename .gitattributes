# Set default behavior to automatically normalize line endings
* text=auto

# Force LF line endings for source code and documentation across all OSes
*.py text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.example text eol=lf
.gitignore text eol=lf
